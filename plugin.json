      "Type": "textbox",
      "Value": {
        "Key": "appKey",
        "Label": "App Key",
        "Suffix": "",
        "DefaultValue": "",
        "Tooltip": "Youdao OpenAPI app key, get it from https://ai.youdao.com/console/",
        "MaxLines": 1,
        "Validators": [],
        "Style": {
          "Width": 500
        }
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "appSecret",
        "Label": "App Secret",
        "Suffix": "",
        "DefaultValue": "",
